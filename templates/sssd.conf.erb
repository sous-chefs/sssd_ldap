[sssd]
config_file_version = 2
services = nss, pam<% if @ldap_autofs %>, autofs<% end %><% if @ldap_ssh %>, ssh<% end %><% if @ldap_sudo %>, sudo<% end %>
domains = LDAP

[nss]
filter_users = <%= @filter_users.join(',') %>
filter_groups = <%= @filter_groups.join(',') %>

[pam]

[domain/LDAP]
<% @sssd_conf.each do |key, value| %>
<% if not value.nil? %><%=  key %> = <%= value %><% end %>
<% end %>
